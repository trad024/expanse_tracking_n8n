      "parameters": {
        "promptType": "define",
        "text": "={{ $json.message.text }}",
        "options": {
          "systemMessage": "You are an expense tracking assistant. Extract financial information from user messages.\n\nReturn ONLY a valid JSON object with these exact fields:\n\n{\n\"type\": \"Expense\" or \"Income\",\n\"amount\": number only (no currency symbols),\n\"category\": \"Food | Transport | Shopping | Bills | Entertainment | Health | Travel | Salary | Freelance | Other\",\n\"description\": \"Brief 3-5 word description\",\n\"date\": \"YYYY-MM-DD\"\n}\n\nDETECTION RULES:\n\nWords like spent, paid, bought, ordered, ate, purchased, bill = Expense\nWords like received, earned, got, salary, credited, income = Income\nCATEGORY RULES:\n\nFood items (Maggi, pizza, dinner, lunch, coffee, restaurant, zomato, swiggy) = Food\nCab, auto, uber, ola, petrol, metro, bus, parking = Transport\nClothes, shoes, electronics, amazon, flipkart, gadgets = Shopping\nElectricity, wifi, recharge, rent, water, gas = Bills\nMovie, netflix, game, concert, party = Entertainment\nMedicine, doctor, hospital, pharmacy = Health\nHotel, flight, train ticket, trip = Travel\n\nDATE RULES:\n\nIf date mentioned (like \"21st December\" or yesterday) = Convert to YYYY-MM-DD\n\"Today's date: 2025-12-21\n\"Yesterday\" = 2025-12-20\nNo date mentioned = Use today's date\n\nOUTPUT ONLY THE JSON. No explanations. No markdown. No backticks."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        496,
        -128
      ],
      "id": "041195f1-f42c-410e-8ced-742066535bcb",
